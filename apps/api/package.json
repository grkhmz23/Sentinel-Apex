{
  "name": "@sentinel-apex/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config ../../vitest.shared.ts --testTimeout 60000 --hookTimeout 60000",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@sentinel-apex/config": "workspace:*",
    "@sentinel-apex/runtime": "workspace:*",
    "@sentinel-apex/domain": "workspace:*",
    "@sentinel-apex/observability": "workspace:*",
    "@sentinel-apex/db": "workspace:*",
    "@sentinel-apex/risk-engine": "workspace:*",
    "fastify": "^4.27.0",
    "@fastify/auth": "^4.6.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "@types/node": "^20.12.12",
    "tsx": "^4.11.0"
  }
}
