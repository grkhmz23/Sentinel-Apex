{
  "name": "sentinel-apex",
  "private": true,
  "version": "0.1.0",
  "description": "Sentinel Apex — algorithmic trading execution and risk management monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "build:frontend": "pnpm --filter @sentinel-apex/ops-dashboard... build",
    "build:api": "pnpm --filter @sentinel-apex/api... build",
    "build:worker": "pnpm --filter @sentinel-apex/runtime-worker... build",
    "dev": "turbo run dev --parallel",
    "worker:dev": "pnpm --filter @sentinel-apex/runtime-worker dev",
    "db:start": "./scripts/db-start.sh",
    "db:stop": "./scripts/db-stop.sh",
    "db:reset": "./scripts/db-reset.sh",
    "db:health": "./scripts/db-health.sh",
    "db:migrate": "./scripts/db-migrate.sh",
    "test": "turbo run test --concurrency=4",
    "test:ci": "turbo run test --concurrency=1",
    "test:workspace": "vitest run --config vitest.config.ts",
    "lint": "turbo run lint --concurrency=4",
    "lint:ci": "turbo run lint --concurrency=1",
    "format": "prettier --write \"**/*.{ts,tsx,js,cjs,mjs,json,yaml,yml,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,cjs,mjs,json,yaml,yml,md}\" --ignore-path .gitignore",
    "start:frontend": "pnpm --filter @sentinel-apex/ops-dashboard start",
    "start:api": "pnpm --filter @sentinel-apex/api start",
    "start:worker": "pnpm --filter @sentinel-apex/runtime-worker start",
    "smoke:backend": "./scripts/smoke-backend.sh",
    "smoke:frontend": "./scripts/smoke-frontend.sh",
    "typecheck": "turbo run typecheck",
    "validate": "pnpm build && pnpm typecheck && pnpm lint && pnpm test",
    "validate:ci": "CI=1 pnpm build && CI=1 pnpm typecheck && CI=1 pnpm lint:ci && CI=1 pnpm test:ci",
    "release:check": "CI=1 pnpm validate:ci && pnpm format:check",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "prettier": "^3.3.0",
    "turbo": "^2.0.6",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "pnpm": {
    "overrides": {
      "typescript": "^5.4.5"
    }
  },
  "dependencies": {
    "tslib": "^2.8.1"
  }
}
