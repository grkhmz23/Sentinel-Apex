{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "LOG_LEVEL",
    "EXECUTION_MODE"
  ],
  "globalDependencies": [
    ".env",
    ".eslintrc.cjs",
    "package.json",
    "pnpm-lock.yaml",
    "tsconfig.base.json",
    "tsconfig.json",
    "vitest.config.ts",
    "vitest.shared.ts"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "env": ["NODE_ENV"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true,
      "env": [
        "NODE_ENV",
        "API_PORT",
        "DATABASE_URL",
        "DRIFT_RPC_ENDPOINT",
        "LOG_LEVEL",
        "EXECUTION_MODE"
      ]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": [],
      "env": ["NODE_ENV", "DATABASE_URL", "EXECUTION_MODE"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "db:generate": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.prisma", "prisma/**", "drizzle/**"],
      "outputs": ["src/generated/**", "drizzle/**"]
    }
  }
}
