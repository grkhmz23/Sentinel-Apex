{
  "name": "@sentinel-apex/runtime",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config ../../vitest.shared.ts --testTimeout 60000 --hookTimeout 60000",
    "lint": "eslint src --ext .ts",
    "dev:run-cycle": "tsx src/scripts/run-dev-cycle.ts",
    "dev:rebuild-projections": "tsx src/scripts/rebuild-projections.ts"
  },
  "dependencies": {
    "@sentinel-apex/carry": "workspace:*",
    "@sentinel-apex/config": "workspace:*",
    "@sentinel-apex/db": "workspace:*",
    "@sentinel-apex/domain": "workspace:*",
    "@sentinel-apex/execution": "workspace:*",
    "@sentinel-apex/observability": "workspace:*",
    "@sentinel-apex/risk-engine": "workspace:*",
    "@sentinel-apex/strategy-engine": "workspace:*",
    "@sentinel-apex/treasury": "workspace:*",
    "@sentinel-apex/venue-adapters": "workspace:*",
    "decimal.js": "^10.4.3",
    "drizzle-orm": "^0.30.10"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
