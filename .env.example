# =============================================================================
# Sentinel Apex — Environment Variable Template
# =============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit your .env file. Only .env.example belongs in version control.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────

# Runtime environment: development | test | staging | production
NODE_ENV=development

# Log verbosity: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Execution mode — controls whether orders are sent to the exchange.
# Set to "live" only in production after thorough testing.
# Options: dry-run | live
EXECUTION_MODE=dry-run

# Honest deployment label surfaced in backend logs and readiness payloads.
SENTINEL_ENVIRONMENT_LABEL=staging demo

# Honest execution badge surfaced in backend readiness payloads.
SENTINEL_EXECUTION_BADGE=devnet only

# ── Frontend (public / Vercel-safe) ──────────────────────────────────────────

# Public backend base URL for the ops dashboard deployment.
# The dashboard server routes can also read OPS_DASHBOARD_API_BASE_URL if you
# prefer to keep the backend URL server-only.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Public environment label shown in the dashboard deployment banner.
NEXT_PUBLIC_ENVIRONMENT_LABEL=staging demo

# Public execution badge shown in the dashboard deployment banner.
NEXT_PUBLIC_EXECUTION_BADGE=devnet only

# ── Frontend (server-only / Vercel) ──────────────────────────────────────────

# Server-side backend base URL for Next.js route handlers.
# If unset, the dashboard falls back to NEXT_PUBLIC_API_BASE_URL.
OPS_DASHBOARD_API_BASE_URL=http://localhost:3000

# API key used by the dashboard's server-side route handlers.
# Set this to the same value as API_SECRET_KEY on the backend.
OPS_DASHBOARD_API_KEY=

# Shared secret used by the dashboard to sign operator proxy headers and by the
# backend API to verify them. Must match across Vercel and Render.
OPS_AUTH_SHARED_SECRET=

# Cookie/session settings for the ops dashboard.
OPS_DASHBOARD_SESSION_COOKIE_NAME=sentinel_apex_ops_session
OPS_DASHBOARD_SESSION_TTL_HOURS=12
OPS_DASHBOARD_DEFAULT_SIGN_IN_EMAIL=

# ── API Server ────────────────────────────────────────────────────────────────

# Port the REST/WebSocket API listens on
API_PORT=3000

# Secret used to sign JWT tokens and HMAC request signatures — generate with:
#   openssl rand -hex 64
API_SECRET_KEY=

# Optional allowed origin for browser-based API calls.
# For Vercel -> Render demo deployments, set this to your Vercel app URL.
CORS_ORIGIN=http://localhost:3001

# ── Database ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
# This is required by both the backend services and the ops dashboard because
# operator sessions are stored in the shared application database.
DATABASE_URL=postgresql://sentinel:sentinel@localhost:5432/sentinel_apex

# Connection pool sizing
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Solana / On-chain ─────────────────────────────────────────────────────────
SOLANA_RPC_ENDPOINT=https://api.mainnet-beta.solana.com

# ── Jupiter Perpetuals ────────────────────────────────────────────────────────
# Jupiter Perps is the primary execution venue for hackathon demonstration.
# Uses USDC collateral on devnet for BTC-PERP, ETH-PERP, SOL-PERP markets.
JUPITER_PERPS_ENABLED=true
JUPITER_PERPS_NETWORK=devnet
JUPITER_PERPS_RPC_ENDPOINT=https://api.devnet.solana.com
JUPITER_PERPS_API_ENDPOINT=https://perps-api.jup.ag/v2

# Wallet for Jupiter Perps trading (devnet only for hackathon)
# Base58-encoded private key or JSON array
JUPITER_PERPS_PRIVATE_KEY=
JUPITER_PERPS_SUBACCOUNT_ID=0
JUPITER_PERPS_ACCOUNT_LABEL=Hackathon Devnet Account

# ── Metrics & Observability ───────────────────────────────────────────────────

# Enable Prometheus /metrics endpoint
METRICS_ENABLED=true

# Port for the Prometheus metrics server
METRICS_PORT=9090

# ── Alerting ─────────────────────────────────────────────────────────────────

# Webhook URL for critical alerts (Slack, PagerDuty, Discord, etc.)
ALERT_WEBHOOK_URL=

# ── Feature Flags ─────────────────────────────────────────────────────────────

# Master switch for live order execution — must be explicitly set to "true".
# Defaults to false; dry-run mode remains active until this is enabled.
FEATURE_FLAG_LIVE_EXECUTION=false

# ── Runtime Worker ───────────────────────────────────────────────────────────

# Dedicated worker cycle interval in milliseconds. Keep this conservative in local/dev.
RUNTIME_WORKER_CYCLE_INTERVAL_MS=60000
